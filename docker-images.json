[
  {
    "containerName": "jellyfin",
    "iconUrl": "https://cdn.jsdelivr.net/gh/homarr-labs/dashboard-icons/png/jellyfin.png",
    "category": "Media",
    "port":"8096",
    "helpLink":"https://jellyfin.org/docs/general/getting-help/",
    "imageName": "lscr.io/linuxserver/jellyfin:latest",
    "excerpt": "Stream your movies, TV shows, and music from your own server.",
    "description": "Jellyfin is a free and open-source media server that organizes and streams your personal media library to virtually any device. It supports movies, TV shows, music, live TV, DVR, and user accounts without requiring a subscription.",
    "service": {
      "image": "lscr.io/linuxserver/jellyfin:latest",
      "container_name": "jellyfin",
      "environment": [
        "PUID=1000",
        "PGID=1000",
        "TZ=America/New_York"
      ],
      "volumes": [
        "./config/jellyfin:/config",
        "./media/movies:/data/movies",
        "./media/tv:/data/tv"
      ],
      "ports": [
        "8096:8096"
      ],
      "restart": "unless-stopped"
    }
  },
  {
    "containerName": "prowlarr",
    "iconUrl": "https://cdn.jsdelivr.net/gh/homarr-labs/dashboard-icons/png/prowlarr.png",
    "category": "Media",
    "port":"9696",
    "helpLink":"https://prowlarr.com/",
    "imageName": "lscr.io/linuxserver/prowlarr:latest",
    "excerpt": "Manage all your indexers from one place.",
    "description": "Prowlarr centralizes indexer management for applications like Sonarr, Radarr, Lidarr, and Readarr. Configure your indexers once and automatically sync them across your media automation stack.",
    "service": {
      "image": "lscr.io/linuxserver/prowlarr:latest",
      "container_name": "prowlarr",
      "environment": [
        "PUID=1000",
        "PGID=1000",
        "TZ=America/New_York"
      ],
      "volumes": [
        "./config/prowlarr:/config"
      ],
      "ports": [
        "9696:9696"
      ],
      "restart": "unless-stopped"
    }
  },
  {
  "containerName": "qui",
  "iconUrl": "https://cdn.jsdelivr.net/gh/selfhst/icons/png/qui-dark.png",
  "category": "Utilities",
  "port": "7476",
  "helpLink": "https://getqui.com/",
  "imageName": "ghcr.io/autobrr/qui:latest",
  "excerpt": "A lightweight web interface for managing and viewing files.",
  "description": "Qui is a lightweight web application from the autobrr project that provides a simple interface for browsing and managing files through your browser.",
  "service": {
    "image": "ghcr.io/autobrr/qui:latest",
    "container_name": "qui",
    "restart": "unless-stopped",
    "ports": [
      "7476:7476"
    ],
    "volumes": [
      "./config:/config"
    ]
  }
  },
  {
    "containerName": "qbittorrent",
    "iconUrl": "https://cdn.jsdelivr.net/gh/homarr-labs/dashboard-icons/png/qbittorrent.png",
    "category": "Torrent",
    "port":"8080",
    "helpLink":"https://www.qbittorrent.org/",
    "imageName": "lscr.io/linuxserver/qbittorrent:latest",
    "excerpt": "A lightweight BitTorrent client with a powerful web interface.",
    "description": "qBittorrent is an open-source BitTorrent client that provides fast downloads, RSS support, search plugins, bandwidth scheduling, and a modern web UI for managing torrents from anywhere.",
    "service": {
      "image": "lscr.io/linuxserver/qbittorrent:latest",
      "container_name": "qbittorrent",
      "environment": [
        "PUID=1000",
        "PGID=1000",
        "TZ=America/New_York",
        "WEBUI_PORT=8080"
      ],
      "volumes": [
        "./config/qbittorrent:/config",
        "./downloads:/downloads"
      ],
      "ports": [
        "8080:8080",
        "6881:6881",
        "6881:6881/udp"
      ],
      "restart": "unless-stopped"
    }
  },
  {
    "containerName": "glances",
    "iconUrl": "https://cdn.jsdelivr.net/gh/homarr-labs/dashboard-icons/png/glances.png",
    "category": "System",
    "port":"61208",
    "helpLink":"https://glances.readthedocs.io/en/latest/",
    "imageName": "nicolargo/glances:latest",
    "excerpt": "Monitor your system's performance in real time.",
    "description": "Glances is a cross-platform system monitoring tool that displays CPU, memory, disk, network, process, and container statistics through an intuitive web interface or terminal dashboard.",
    "service": {
      "image": "nicolargo/glances:latest",
      "container_name": "glances",
      "restart": "unless-stopped",
      "pid": "host",
      "network_mode": "host",
      "environment": [
        "GLANCES_OPT=-w",
        "TZ=America/New_York"
      ],
      "volumes": [
        "/var/run/docker.sock:/var/run/docker.sock:ro"
      ]
    }
  },
  {
    "containerName": "uptime-kuma",
    "iconUrl": "https://cdn.jsdelivr.net/gh/homarr-labs/dashboard-icons/png/uptime-kuma.png",
    "category": "Metrics",
    "port":"3001",
    "helpLink":"https://uptimekuma.org/",
    "imageName": "louislam/uptime-kuma:latest",
    "excerpt": "Monitor your services and get notified when they go offline.",
    "description": "Uptime Kuma is a self-hosted uptime monitoring solution that checks the availability of websites, APIs, servers, and services. It includes status pages, notifications, and response time tracking.",
    "service": {
      "image": "louislam/uptime-kuma:1",
      "container_name": "uptime-kuma",
      "restart": "unless-stopped",
      "ports": [
        "3001:3001"
      ],
      "volumes": [
        "./data:/app/data"
      ]
    }
  },
  {
    "containerName": "minecraft",
    "iconUrl": "https://cdn.jsdelivr.net/gh/homarr-labs/dashboard-icons/png/minecraft.png",
    "category": "Games",
    "port":"25565",
    "helpLink":"https://help.minecraft.net/hc/en-us",
    "imageName": "itzg/minecraft-server:latest",
    "excerpt": "Host your own Minecraft server in minutes.",
    "description": "The itzg Minecraft Server container makes it easy to run a customizable Minecraft server with support for Vanilla, Paper, Spigot, Fabric, Forge, and more.",
    "service": {
      "image": "itzg/minecraft-server:latest",
      "container_name": "minecraft",
      "ports": [
        "25565:25565"
      ],
      "environment": {
        "EULA": "TRUE",
        "TYPE": "PAPER",
        "VERSION": "26.2",
        "MEMORY": "6G",
        "MOTD": "Mason's HomeLab Minecraft Server",
        "ENABLE_ROLLING_LOGS": "true"
      },
      "volumes": [
        "./data:/data"
      ],
      "restart": "unless-stopped"
    }
  }
]
